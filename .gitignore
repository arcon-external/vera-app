# --- Wails / Go Binaries ---
*.exe
*.exe~
*.dll
*.so
*.dylib
# Ignore the final compiled binaries in the build directory
build/bin/
# If you use wails build -package, ignore the installers
build/dist/

# --- Go / Testing ---
*.test
*.out
coverage.*
*.coverprofile
profile.cov
go.work
go.work.sum

# --- Node.js / React (Frontend) ---
# Assuming your frontend is in a 'frontend' directory
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.eslintcache
frontend/.stylelintcache

# --- Tailwind / Vite / PostCSS ---
# If you use Vite (standard with Wails v2+), ignore its cache
.vite/
frontend/.vite/

# --- Environment & Logs ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- Editor / IDE ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- OS Specific ---
.DS_Store
Thumbs.db
